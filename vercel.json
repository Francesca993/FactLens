{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "cleanUrls": true,
  "builds": [
    {
      "src": "api/fakenews.py",
      "use": "@vercel/python"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/fakenews",
      "dest": "/api/fakenews.py"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/",
      "dest": "/public"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}